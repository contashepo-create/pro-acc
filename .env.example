# ==================== Supabase ====================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (for direct pg connection - optional if using Supabase REST)
DATABASE_URL=postgresql://user:password@host:port/dbname

# ==================== Auth ====================
# JWT Token Secret (REQUIRED — use: openssl rand -hex 32)
TOKEN_SECRET=your-strong-random-secret-min-32-chars

# License Salt (REQUIRED — for activation code generation)
PRO_ACCOUNTANT_LICENSE_SALT=your-license-salt-random-string

# ==================== Admin Panel ====================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_MASTER_PASSWORD=your-master-password
ADMIN_PATH=zerocold

# ==================== Telegram Bot (for Admin 2FA) ====================
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# ==================== Email (SMTP) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ==================== Security ====================
# Cloudflare Turnstile (Recommended for production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# CSRF - set to true to bypass in local development only
CSRF_BYPASS=false

# Feature flags
CAPTCHA_ENABLED=true
