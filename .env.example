# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Telegram Bot for Admin Panel
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# JWT Token Secret (REQUIRED — use a strong random string)
TOKEN_SECRET=your-strong-random-secret

# License Salt (REQUIRED — for activation code generation)
PRO_ACCOUNTANT_LICENSE_SALT=your-license-salt

# Admin Panel
ADMIN_PASSWORD=your-admin-password
ADMIN_MASTER_PASSWORD=your-master-password
ADMIN_EMAIL=admin@example.com
ADMIN_PATH=zerocold
